{
  "defaultsConfig": {
    "useAllDefaults": true
  },
  "inputDir": "./posts",
  "outputDir": "./src/posts",
  "matchers": [
    {
      "pattern": "(?<!\\w){(?<body>.+?)}\\(\\((?<comment>.+?)\\)\\)(?!\\w)",
      "tag": "com",
      "subgroups": "comment"
    },
    {
      "pattern": "(?<!\\w)%(?<body>.+?)%\\(\\((?<definition>.+?)\\)\\)(?!\\w)",
      "tag": "def",
      "subgroups": "definition"
    }
  ]
}
